generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission{
  id  String @id @default(uuid())
  code String
  language String 
  problemId Int?
  stdin String?
  status String @default("queued")
  output String?
  stderr String?
  createdAt DateTime @default(now())

}

//stdin and stderr are for input related to a specific submission 
