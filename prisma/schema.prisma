generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id        String   @id @default(uuid())
  code      String
  language  String
  stdin     String?
  status    String   @default("queued")
  output    String?
  stderr    String?
  createdAt DateTime @default(now())
  problemId Int?
}
